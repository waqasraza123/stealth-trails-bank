# Worker identity
WORKER_ID=worker-local-1

# Internal API
INTERNAL_API_BASE_URL=http://localhost:9001
INTERNAL_WORKER_API_KEY=

# Execution mode:
# - monitor: production-safe default, no auto-broadcast, confirms/settles real broadcast txs via RPC
# - managed: production execution for platform-originated deposits using a dedicated worker signer
# - synthetic: local/dev only, simulates broadcast/confirm/settle end-to-end
WORKER_EXECUTION_MODE=monitor

# Polling
WORKER_POLL_INTERVAL_MS=10000
WORKER_BATCH_LIMIT=20
WORKER_REQUEST_TIMEOUT_MS=10000
WORKER_CONFIRMATION_BLOCKS=1

# Required for monitor mode
RPC_URL=http://127.0.0.1:8545

# Required for managed mode
# Use a narrowly scoped operational signer, not a treasury root key.
WORKER_DEPOSIT_SIGNER_PRIVATE_KEY=
