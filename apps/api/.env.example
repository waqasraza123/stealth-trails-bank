# API server
API_PORT=9001
# Required in production. Comma-separated bare origins only, for example:
# CORS_ALLOWED_ORIGINS=https://bank.example.com,https://ops.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (Prisma)
DATABASE_URL=
DIRECT_URL=

# JWT Auth
JWT_SECRET=
JWT_EXPIRY_SECONDS=86400
# Supabase-backed operator auth
SUPABASE_JWT_SECRET=
OPERATOR_RUNTIME_ENVIRONMENT=development
ALLOW_LEGACY_OPERATOR_API_KEY_AUTH=true
# OPERATOR_REQUIRED_MFA_ENVIRONMENTS=staging,production_like,production
INTERNAL_OPERATOR_API_KEY=
INTERNAL_WORKER_API_KEY=
# Sensitive operator control roles
# TRANSACTION_INTENT_DECISION_ALLOWED_OPERATOR_ROLES=operations_admin,risk_manager
# CUSTODY_OPERATION_ALLOWED_OPERATOR_ROLES=operations_admin,senior_operator,treasury
# STAKING_GOVERNANCE_ALLOWED_OPERATOR_ROLES=treasury,risk_manager,compliance_lead
# STAKING_POOL_GOVERNANCE_REQUEST_ALLOWED_OPERATOR_ROLES=treasury,risk_manager,compliance_lead
# STAKING_POOL_GOVERNANCE_APPROVER_ALLOWED_OPERATOR_ROLES=risk_manager,compliance_lead
# STAKING_POOL_GOVERNANCE_EXECUTOR_ALLOWED_OPERATOR_ROLES=treasury

# Shared login bootstrap
# Local-development convenience only. In production this now defaults to disabled
# unless SHARED_LOGIN_ENABLED is explicitly set to true with non-default credentials.
SHARED_LOGIN_ENABLED=true
SHARED_LOGIN_EMAIL=admin@gmail.com
SHARED_LOGIN_PASSWORD=P@ssw0rd
SHARED_LOGIN_FIRST_NAME=Shared
SHARED_LOGIN_LAST_NAME=Admin
SHARED_LOGIN_SUPABASE_USER_ID=shared-login-admin

# Ethereum / Hardhat local node defaults shown
RPC_URL=http://127.0.0.1:8545
STAKING_CONTRACT_ADDRESS=
ETHEREUM_PRIVATE_KEY=
# Governed custody and deployment metadata
# GOVERNED_CUSTODY_MANIFEST_PATH=packages/contracts/deployments/local.manifest.json
# GOVERNED_CUSTODY_MANIFEST_JSON=
# GOVERNED_EXECUTION_PACKAGE_SIGNER_PRIVATE_KEY=
# GOVERNED_LOAN_FUNDING_EXECUTION_MODE=governed_external
# GOVERNED_STAKING_WRITE_EXECUTION_MODE=governed_external

# Platform alert delivery and follow-up
# PLATFORM_ALERT_DELIVERY_TARGETS_JSON=[]
# PLATFORM_ALERT_DELIVERY_REQUEST_TIMEOUT_MS=5000
# PLATFORM_ALERT_AUTOMATION_POLICIES_JSON=[]
# PLATFORM_ALERT_DELIVERY_HEALTH_SLO_JSON={"lookbackHours":24,"minimumRecentDeliveries":3,"warningFailureRatePercent":25,"criticalFailureRatePercent":50,"warningPendingCount":2,"criticalPendingCount":5,"warningAverageDeliveryLatencyMs":15000,"criticalAverageDeliveryLatencyMs":60000,"warningConsecutiveFailures":2,"criticalConsecutiveFailures":3}
# PLATFORM_ALERT_REESCALATION_UNACKNOWLEDGED_SECONDS=900
# PLATFORM_ALERT_REESCALATION_UNOWNED_SECONDS=600
# PLATFORM_ALERT_REESCALATION_REPEAT_SECONDS=1800
