  evidenceType             ReleaseReadinessEvidenceType
  environment              ReleaseReadinessEnvironment
  status                   ReleaseReadinessEvidenceStatus
  releaseIdentifier        String?
  rollbackReleaseIdentifier String?
  backupReference          String?
  summary                  String
  note                     String?
  operatorId               String
  operatorRole             String?
  runbookPath              String?
  evidenceLinks            String[]
  evidencePayload          Json?
  startedAt                DateTime?
  completedAt              DateTime?
  observedAt               DateTime                       @default(now())
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  @@index([evidenceType, environment, observedAt])
  @@index([status, observedAt])
  @@index([operatorId, observedAt])
  @@index([releaseIdentifier, observedAt])
}

