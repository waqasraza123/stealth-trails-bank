datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String           @unique
  supabaseUserId  String
  ethereumAddress String?          @default("")
  createdAt       DateTime         @default(now())
  deposits        PoolDeposit[]
  withdrawals     PoolWithdrawal[]
}

model Customer {
  id                 String              @id @default(cuid())
  supabaseUserId     String              @unique
  email              String              @unique
  firstName          String?
  lastName           String?
  passwordHash       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           CustomerAccount[]
  reviewCases        ReviewCase[]
  auditEvents        AuditEvent[]
  oversightIncidents OversightIncident[] @relation("OversightIncidentCustomer")
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
}

model CustomerAccount {
  id                              String                       @id @default(cuid())
  customerId                      String                       @unique
  customer                        Customer                     @relation(fields: [customerId], references: [id])
  status                          AccountLifecycleStatus       @default(registered)
  activatedAt                     DateTime?
  restrictedAt                    DateTime?
  restrictedFromStatus            AccountLifecycleStatus?
  restrictionReasonCode           String?
  restrictedByOperatorId          String?
  restrictedByOversightIncidentId String?
  restrictionReleasedAt           DateTime?
  restrictionReleasedByOperatorId String?
  frozenAt                        DateTime?
  closedAt                        DateTime?
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt
  wallets                         Wallet[]
  transactionIntents              TransactionIntent[]
  reviewCases                     ReviewCase[]
  oversightIncidents              OversightIncident[]          @relation("OversightIncidentCustomerAccount")
  restrictionRecords              CustomerAccountRestriction[]

  @@index([status])
  @@index([restrictedByOversightIncidentId])
  ledgerAccounts                  LedgerAccount[]
  assetBalances                   CustomerAssetBalance[]
  incidentPackageReleases         CustomerAccountIncidentPackageRelease[]
  ledgerReconciliationMismatches  LedgerReconciliationMismatch[]
}

model Wallet {
  id                 String              @id @default(cuid())
  customerAccountId  String?
  customerAccount    CustomerAccount?    @relation(fields: [customerAccountId], references: [id])
  chainId            Int
  address            String
  kind               WalletKind
  custodyType        WalletCustodyType
  status             WalletStatus        @default(pending)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sourceIntents      TransactionIntent[] @relation("SourceWallet")
  destinationIntents TransactionIntent[] @relation("DestinationWallet")

  @@unique([chainId, address])
  @@index([customerAccountId])
  @@index([kind, custodyType])
  @@index([status])
}

model Asset {
  id                 String              @id @default(cuid())
  chainId            Int
  symbol             String
  displayName        String
  decimals           Int
  assetType          AssetType
  contractAddress    String?
  status             AssetStatus         @default(active)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  transactionIntents TransactionIntent[]

  @@unique([chainId, symbol])
  @@unique([chainId, contractAddress])
  @@index([assetType, status])
  ledgerAccounts     LedgerAccount[]
  ledgerJournals     LedgerJournal[]
  customerBalances   CustomerAssetBalance[]
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
}

model TransactionIntent {
  id                           String                  @id @default(cuid())
  customerAccountId            String?
  customerAccount              CustomerAccount?        @relation(fields: [customerAccountId], references: [id])
  assetId                      String
  asset                        Asset                   @relation(fields: [assetId], references: [id])
  sourceWalletId               String?
  sourceWallet                 Wallet?                 @relation("SourceWallet", fields: [sourceWalletId], references: [id])
  destinationWalletId          String?
  destinationWallet            Wallet?                 @relation("DestinationWallet", fields: [destinationWalletId], references: [id])
  externalAddress              String?
  chainId                      Int
  intentType                   TransactionIntentType
  status                       TransactionIntentStatus
  policyDecision               PolicyDecision          @default(pending)
  requestedAmount              Decimal                 @db.Decimal(36, 18)
  settledAmount                Decimal?                @db.Decimal(36, 18)
  idempotencyKey               String                  @unique
  failureCode                  String?
  failureReason                String?
  manuallyResolvedAt           DateTime?
  manualResolutionReasonCode   String?
  manualResolutionNote         String?
  manualResolvedByOperatorId   String?
  manualResolutionOperatorRole String?
  manualResolutionReviewCaseId String?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  blockchainTransactions       BlockchainTransaction[]
  reviewCases                  ReviewCase[]

  @@index([customerAccountId])
  @@index([assetId])
  @@index([sourceWalletId])
  @@index([destinationWalletId])
  @@index([chainId, intentType])
  @@index([status, policyDecision])
  @@index([chainId, externalAddress])
  @@index([status, manuallyResolvedAt])
  @@index([manualResolvedByOperatorId, manuallyResolvedAt])
  @@index([manualResolutionReasonCode, manuallyResolvedAt])
  ledgerJournal                LedgerJournal?
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
}

model BlockchainTransaction {
  id                  String                      @id @default(cuid())
  transactionIntentId String
  transactionIntent   TransactionIntent           @relation(fields: [transactionIntentId], references: [id])
  chainId             Int
  txHash              String?                     @unique
  nonce               Int?
  status              BlockchainTransactionStatus
  fromAddress         String?
  toAddress           String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  confirmedAt         DateTime?

  @@index([transactionIntentId])
  @@index([chainId, status])
}

model ReviewCase {
  id                  String             @id @default(cuid())
  customerId          String?
  customer            Customer?          @relation(fields: [customerId], references: [id])
  customerAccountId   String?
  customerAccount     CustomerAccount?   @relation(fields: [customerAccountId], references: [id])
  transactionIntentId String?
  transactionIntent   TransactionIntent? @relation(fields: [transactionIntentId], references: [id])
  type                ReviewCaseType
  status              ReviewCaseStatus   @default(open)
  reasonCode          String?
  notes               String?
  assignedOperatorId  String?
  startedAt           DateTime?
  resolvedAt          DateTime?
  dismissedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  events              ReviewCaseEvent[]
  restrictionReleaseReviews CustomerAccountRestriction[] @relation("RestrictionReleaseReviewCase")
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]

  @@index([customerId])
  @@index([customerAccountId])
  @@index([transactionIntentId])
  @@index([type, status])
  @@index([reasonCode])
  @@index([status, assignedOperatorId])
}

model AuditEvent {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  actorType  String
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@index([actorType, actorId])
  @@index([targetType, targetId])
}

model StakingPool {
  id                Int              @id @default(autoincrement())
  blockchainPoolId  Int?             @unique
  rewardRate        Int
  totalStakedAmount BigInt           @default(0)
  totalRewardsPaid  BigInt           @default(0)
  poolStatus        PoolStatus       @default(disabled)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deposits          PoolDeposit[]
  withdrawals       PoolWithdrawal[]
}

enum AccountLifecycleStatus {
  registered
  email_verified
  review_required
  active
  restricted
  frozen
  closed
}

enum WalletKind {
  embedded
  external
  treasury
  operational
  contract
}

enum WalletCustodyType {
  platform_managed
  customer_external
  multisig_controlled
  contract_controlled
}

enum WalletStatus {
  pending
  active
  restricted
  archived
}

enum AssetType {
  native
  erc20
}

enum AssetStatus {
  active
  disabled
}

enum TransactionIntentType {
  deposit
  withdrawal
  vault_subscription
  vault_redemption
  treasury_transfer
  adjustment
}

enum TransactionIntentStatus {
  requested
  review_required
  approved
  queued
  broadcast
  confirmed
  settled
  failed
  cancelled
  manually_resolved
}

enum PolicyDecision {
  pending
  approved
  denied
  review_required
}

enum BlockchainTransactionStatus {
  created
  signed
  broadcast
  confirmed
  failed
  replaced
  dropped
}

enum ReviewCaseStatus {
  open
  in_progress
  resolved
  dismissed
}

enum ReviewCaseType {
  account_review
  withdrawal_review
  reconciliation_review
  manual_intervention
}

enum PoolStatus {
  active
  disabled
  paused
  closed
  completed
}

model PoolDeposit {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool   @relation(fields: [stakingPoolId], references: [id])
  amountStaked    BigInt
  transactionHash String?       @unique @default("")
  status          DepositStatus @default(pending)
  timestamp       DateTime      @default(now())
}

enum DepositStatus {
  pending
  completed
  failed
}

model PoolWithdrawal {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool      @relation(fields: [stakingPoolId], references: [id])
  amountWithdrawn BigInt
  transactionHash String?          @unique @default("")
  status          WithdrawalStatus @default(pending)
  timestamp       DateTime         @default(now())
}

enum WithdrawalStatus {
  pending
  completed
  failed
}

model LedgerAccount {
  id                String            @id @default(cuid())
  ledgerKey         String            @unique
  accountType       LedgerAccountType
  chainId           Int
  assetId           String
  asset             Asset             @relation(fields: [assetId], references: [id])
  customerAccountId String?
  customerAccount   CustomerAccount?  @relation(fields: [customerAccountId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ledgerPostings    LedgerPosting[]

  @@index([accountType, chainId, assetId])
  @@index([customerAccountId, assetId])
}

model LedgerJournal {
  id                  String            @id @default(cuid())
  transactionIntentId String            @unique
  transactionIntent   TransactionIntent @relation(fields: [transactionIntentId], references: [id])
  journalType         LedgerJournalType
  chainId             Int
  assetId             String
  asset               Asset             @relation(fields: [assetId], references: [id])
  postedAt            DateTime          @default(now())
  createdAt           DateTime          @default(now())
  ledgerPostings      LedgerPosting[]

  @@index([journalType, chainId])
  @@index([assetId])
}

model LedgerPosting {
  id              String                 @id @default(cuid())
  ledgerJournalId String
  ledgerJournal   LedgerJournal          @relation(fields: [ledgerJournalId], references: [id])
  ledgerAccountId String
  ledgerAccount   LedgerAccount          @relation(fields: [ledgerAccountId], references: [id])
  direction       LedgerPostingDirection
  amount          Decimal                @db.Decimal(36, 18)
  createdAt       DateTime               @default(now())

  @@index([ledgerJournalId])
  @@index([ledgerAccountId, direction])
}

model CustomerAssetBalance {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])
  assetId           String
  asset             Asset           @relation(fields: [assetId], references: [id])
  availableBalance  Decimal         @default(0) @db.Decimal(36, 18)
  pendingBalance    Decimal         @default(0) @db.Decimal(36, 18)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([customerAccountId, assetId])
  @@index([assetId])
}

model LedgerReconciliationMismatch {
  id                    String                                @id @default(cuid())
  mismatchKey           String                                @unique
  scope                 LedgerReconciliationMismatchScope
  status                LedgerReconciliationMismatchStatus    @default(open)
  severity              LedgerReconciliationMismatchSeverity
  recommendedAction     LedgerReconciliationMismatchRecommendedAction @default(none)
  reasonCode            String
  summary               String
  chainId               Int
  customerId            String?
  customer              Customer?                             @relation(fields: [customerId], references: [id])
  customerAccountId     String?
  customerAccount       CustomerAccount?                      @relation(fields: [customerAccountId], references: [id])
  transactionIntentId   String?
  transactionIntent     TransactionIntent?                    @relation(fields: [transactionIntentId], references: [id])
  assetId               String?
  asset                 Asset?                                @relation(fields: [assetId], references: [id])
  linkedReviewCaseId    String?
  linkedReviewCase      ReviewCase?                           @relation(fields: [linkedReviewCaseId], references: [id])
  latestSnapshot        Json
  resolutionMetadata    Json?
  resolutionNote        String?
  detectionCount        Int                                   @default(1)
  firstDetectedAt       DateTime                              @default(now())
  lastDetectedAt        DateTime                              @default(now())
  resolvedAt            DateTime?
  resolvedByOperatorId  String?
  dismissedAt           DateTime?
  dismissedByOperatorId String?
  createdAt             DateTime                              @default(now())
  updatedAt             DateTime                              @updatedAt

  @@index([status, updatedAt])
  @@index([scope, status, updatedAt])
  @@index([reasonCode, status])
  @@index([recommendedAction, status])
  @@index([customerAccountId, status])
  @@index([transactionIntentId, status])
  @@index([assetId, status])
  @@index([chainId, scope, status])
  @@index([linkedReviewCaseId])
}

enum LedgerAccountType {
  asset_inbound_clearing
  asset_outbound_clearing
  customer_asset_liability
}

enum LedgerJournalType {
  deposit_settlement
  withdrawal_settlement
}

enum LedgerPostingDirection {
  debit
  credit
}

enum LedgerReconciliationMismatchScope {
  transaction_intent
  customer_balance
}

enum LedgerReconciliationMismatchStatus {
  open
  resolved
  dismissed
}

enum LedgerReconciliationMismatchSeverity {
  warning
  critical
}

enum LedgerReconciliationMismatchRecommendedAction {
  none
  replay_confirm
  replay_settle
  open_review_case
  repair_customer_balance
}

model LedgerReconciliationScanRun {
  id                   String                               @id @default(cuid())
  triggerSource        LedgerReconciliationScanTriggerSource
  status               LedgerReconciliationScanRunStatus    @default(running)
  requestedScope       LedgerReconciliationMismatchScope?
  customerAccountId    String?
  transactionIntentId  String?
  triggeredByOperatorId String?
  triggeredByWorkerId  String?
  startedAt            DateTime                             @default(now())
  completedAt          DateTime?
  durationMs           Int?
  createdCount         Int                                  @default(0)
  reopenedCount        Int                                  @default(0)
  refreshedCount       Int                                  @default(0)
  autoResolvedCount    Int                                  @default(0)
  activeMismatchCount  Int                                  @default(0)
  errorCode            String?
  errorMessage         String?
  resultSnapshot       Json?
  createdAt            DateTime                             @default(now())
  updatedAt            DateTime                             @updatedAt

  @@index([status, startedAt])
  @@index([triggerSource, startedAt])
  @@index([requestedScope, startedAt])
  @@index([customerAccountId, startedAt])
  @@index([transactionIntentId, startedAt])
  @@index([triggeredByWorkerId, startedAt])
}

model WorkerRuntimeHeartbeat {
  id                              String                       @id @default(cuid())
  workerId                        String                       @unique
  environment                     WorkerRuntimeEnvironment
  executionMode                   WorkerRuntimeExecutionMode
  lastIterationStatus             WorkerRuntimeIterationStatus
  lastHeartbeatAt                 DateTime                     @default(now())
  lastIterationStartedAt          DateTime?
  lastIterationCompletedAt        DateTime?
  consecutiveFailureCount         Int                          @default(0)
  lastErrorCode                   String?
  lastErrorMessage                String?
  lastReconciliationScanRunId     String?
  lastReconciliationScanStartedAt DateTime?
  lastReconciliationScanCompletedAt DateTime?
  lastReconciliationScanStatus    LedgerReconciliationScanRunStatus?
  runtimeMetadata                 Json?
  latestIterationMetrics          Json?
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt

  @@index([lastHeartbeatAt])
  @@index([lastIterationStatus, lastHeartbeatAt])
  @@index([executionMode, lastHeartbeatAt])
  @@index([lastReconciliationScanStatus, lastHeartbeatAt])
}

model PlatformAlert {
  id                       String                         @id @default(cuid())
  dedupeKey                String                         @unique
  category                 PlatformAlertCategory
  severity                 PlatformAlertSeverity
  status                   PlatformAlertStatus            @default(open)
  routingStatus            PlatformAlertRoutingStatus     @default(unrouted)
  routingTargetType        PlatformAlertRoutingTargetType?
  routingTargetId          String?
  routedAt                 DateTime?
  routedByOperatorId       String?
  routingNote              String?
  ownerOperatorId          String?
  ownerAssignedAt          DateTime?
  ownerAssignedByOperatorId String?
  ownershipNote            String?
  acknowledgedAt           DateTime?
  acknowledgedByOperatorId String?
  acknowledgementNote      String?
  suppressedUntil          DateTime?
  suppressedByOperatorId   String?
  suppressionNote          String?
  code                     String
  summary                  String
  detail                   String?
  metadata                 Json?
  firstDetectedAt          DateTime                       @default(now())
  lastDetectedAt           DateTime                       @default(now())
  resolvedAt               DateTime?
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt
  deliveries               PlatformAlertDelivery[]

  @@index([status, severity, updatedAt])
  @@index([status, routingStatus, updatedAt])
  @@index([status, ownerOperatorId, updatedAt])
  @@index([status, acknowledgedAt, updatedAt])
  @@index([status, suppressedUntil, updatedAt])
  @@index([category, status, updatedAt])
  @@index([code, status, updatedAt])
  @@index([lastDetectedAt])
}

model PlatformAlertDelivery {
  id                      String                         @id @default(cuid())
  platformAlertId         String
  platformAlert           PlatformAlert                  @relation(fields: [platformAlertId], references: [id])
  targetName              String
  targetUrl               String
  eventType               PlatformAlertDeliveryEventType
  escalatedFromDeliveryId String?
  escalatedFromDelivery   PlatformAlertDelivery?         @relation("PlatformAlertDeliveryEscalation", fields: [escalatedFromDeliveryId], references: [id])
  escalatedDeliveries     PlatformAlertDelivery[]        @relation("PlatformAlertDeliveryEscalation")
  escalationLevel         Int                            @default(0)
  escalationReason        String?
  status                  PlatformAlertDeliveryStatus    @default(pending)
  attemptCount            Int                            @default(0)
  requestPayload          Json
  responseStatusCode      Int?
  errorMessage            String?
  lastAttemptedAt         DateTime?
  deliveredAt             DateTime?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt

  @@index([platformAlertId, createdAt])
  @@index([status, createdAt])
  @@index([targetName, status, createdAt])
  @@index([escalatedFromDeliveryId, createdAt])
  @@index([platformAlertId, escalationLevel, createdAt])
}

model ReviewCaseEvent {
  id           String              @id @default(cuid())
  reviewCaseId String
  reviewCase   ReviewCase          @relation(fields: [reviewCaseId], references: [id])
  actorType    String
  actorId      String?
  eventType    ReviewCaseEventType
  note         String?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([reviewCaseId, createdAt])
  @@index([eventType, createdAt])
}

enum ReviewCaseEventType {
  opened
  started
  note_added
  handed_off
  manual_resolution_applied
  account_release_requested
  account_release_approved
  account_release_denied
  resolved
  dismissed
}

enum LedgerReconciliationScanTriggerSource {
  operator
  worker
  system
}

enum LedgerReconciliationScanRunStatus {
  running
  succeeded
  failed
}

enum WorkerRuntimeIterationStatus {
  running
  succeeded
  failed
}

enum PlatformAlertCategory {
  worker
  reconciliation
  queue
  chain
  treasury
  operations
}

enum PlatformAlertSeverity {
  warning
  critical
}

enum PlatformAlertStatus {
  open
  resolved
}

enum PlatformAlertRoutingStatus {
  unrouted
  routed
}

enum PlatformAlertRoutingTargetType {
  review_case
}

enum PlatformAlertDeliveryEventType {
  opened
  reopened
  routed_to_review_case
  owner_assigned
  acknowledged
  re_escalated
  suppressed
  suppression_cleared
}

enum PlatformAlertDeliveryStatus {
  pending
  succeeded
  failed
}

enum WorkerRuntimeEnvironment {
  development
  test
  production
}

enum WorkerRuntimeExecutionMode {
  monitor
  synthetic
  managed
}

model OversightIncident {
  id                       String                  @id @default(cuid())
  incidentType             OversightIncidentType
  status                   OversightIncidentStatus @default(open)
  reasonCode               String?
  summaryNote              String?
  subjectCustomerId        String?
  subjectCustomer          Customer?               @relation("OversightIncidentCustomer", fields: [subjectCustomerId], references: [id])
  subjectCustomerAccountId String?
  subjectCustomerAccount   CustomerAccount?        @relation("OversightIncidentCustomerAccount", fields: [subjectCustomerAccountId], references: [id])
  subjectOperatorId        String?
  subjectOperatorRole      String?
  assignedOperatorId       String?
  openedAt                 DateTime                @default(now())
  startedAt                DateTime?
  resolvedAt               DateTime?
  dismissedAt              DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  events                   OversightIncidentEvent[]
  restrictionRecords       CustomerAccountRestriction[]

  @@index([incidentType, status])
  @@index([subjectCustomerAccountId])
  @@index([subjectOperatorId])
  @@index([assignedOperatorId, status])
  @@index([reasonCode])
}

model OversightIncidentEvent {
  id                  String                    @id @default(cuid())
  oversightIncidentId String
  oversightIncident   OversightIncident         @relation(fields: [oversightIncidentId], references: [id])
  actorType           String
  actorId             String?
  eventType           OversightIncidentEventType
  note                String?
  metadata            Json?
  createdAt           DateTime                  @default(now())

  @@index([oversightIncidentId, createdAt])
  @@index([eventType, createdAt])
}

model CustomerAccountRestriction {
  id                            String                                          @id @default(cuid())
  customerAccountId             String
  customerAccount               CustomerAccount                                 @relation(fields: [customerAccountId], references: [id])
  oversightIncidentId           String
  oversightIncident             OversightIncident                               @relation(fields: [oversightIncidentId], references: [id])
  status                        CustomerAccountRestrictionStatus                @default(active)
  restrictionReasonCode         String
  appliedByOperatorId           String
  appliedByOperatorRole         String?
  appliedNote                   String?
  previousStatus                AccountLifecycleStatus
  appliedAt                     DateTime                                        @default(now())
  releasedAt                    DateTime?
  releasedByOperatorId          String?
  releasedByOperatorRole        String?
  releaseNote                   String?
  restoredStatus                AccountLifecycleStatus?
  releaseDecisionStatus         CustomerAccountRestrictionReleaseDecisionStatus @default(not_requested)
  releaseRequestedAt            DateTime?
  releaseRequestedByOperatorId  String?
  releaseRequestNote            String?
  releaseDecidedAt              DateTime?
  releaseDecidedByOperatorId    String?
  releaseDecisionNote           String?
  releaseReviewCaseId           String?
  releaseReviewCase             ReviewCase?                                     @relation("RestrictionReleaseReviewCase", fields: [releaseReviewCaseId], references: [id])
  createdAt                     DateTime                                        @default(now())
  updatedAt                     DateTime                                        @updatedAt

  @@index([customerAccountId, status])
  @@index([customerAccountId, oversightIncidentId, status], map: "CustomerAccountRestriction_customerAccountId_oversightIncidentI")
  @@index([oversightIncidentId, status])
  @@index([restrictionReasonCode, status])
  @@index([appliedByOperatorId, appliedAt])
  @@index([releasedByOperatorId, releasedAt])
  @@index([releaseDecisionStatus, releaseRequestedAt], map: "CustomerAccountRestriction_releaseDecisionStatus_releaseRequest")
  @@index([releaseReviewCaseId])
  @@index([appliedAt])
  @@index([releasedAt])
}

enum OversightIncidentType {
  customer_manual_resolution_spike
  operator_manual_resolution_spike
}

enum OversightIncidentStatus {
  open
  in_progress
  resolved
  dismissed
}

enum OversightIncidentEventType {
  opened
  started
  note_added
  account_restriction_applied
  account_restriction_released
  resolved
  dismissed
}

enum CustomerAccountRestrictionStatus {
  active
  released
}

enum CustomerAccountRestrictionReleaseDecisionStatus {
  not_requested
  pending
  approved
  denied
}

enum IncidentPackageExportMode {
  internal_full
  redaction_ready
  compliance_focused
}

enum IncidentPackageReleaseTarget {
  internal_casefile
  compliance_handoff
  regulator_response
  external_counsel
}

enum CustomerAccountIncidentPackageReleaseStatus {
  pending_approval
  approved
  rejected
  released
  expired
}

enum ReleaseReadinessEvidenceType {
  platform_alert_delivery_slo
  critical_alert_reescalation
  database_restore_drill
  api_rollback_drill
  worker_rollback_drill
}

enum ReleaseReadinessEnvironment {
  staging
  production_like
  production
}

enum ReleaseReadinessEvidenceStatus {
  pending
  passed
  failed
}

enum ReleaseReadinessApprovalStatus {
  pending_approval
  approved
  rejected
}

model CustomerAccountIncidentPackageRelease {
  id                      String                                      @id @default(cuid())
  customerAccountId       String
  customerAccount         CustomerAccount                             @relation(fields: [customerAccountId], references: [id])
  status                  CustomerAccountIncidentPackageReleaseStatus @default(pending_approval)
  exportMode              IncidentPackageExportMode
  releaseTarget           IncidentPackageReleaseTarget
  releaseReasonCode       String
  requestedByOperatorId   String
  requestedByOperatorRole String?
  approvedByOperatorId    String?
  approvedByOperatorRole  String?
  rejectedByOperatorId    String?
  rejectedByOperatorRole  String?
  releasedByOperatorId    String?
  releasedByOperatorRole  String?
  requestNote             String?
  approvalNote            String?
  rejectionNote           String?
  releaseNote             String?
  artifactChecksumSha256  String
  artifactPayload         Json
  requestedAt             DateTime                                    @default(now())
  approvedAt              DateTime?
  rejectedAt              DateTime?
  releasedAt              DateTime?
  expiresAt               DateTime?
  createdAt               DateTime                                    @default(now())
  updatedAt               DateTime                                    @updatedAt

  @@index([customerAccountId, status])
  @@index([status, requestedAt])
  @@index([status, approvedAt])
  @@index([status, releasedAt])
  @@index([exportMode, status])
  @@index([releaseTarget, status])
  @@index([requestedByOperatorId, requestedAt])
  @@index([approvedByOperatorId, approvedAt])
  @@index([releasedByOperatorId, releasedAt])
}

model ReleaseReadinessEvidence {
