  pending_approval
  approved
  rejected
  executed
  execution_failed
}

enum ReleaseReadinessEvidenceType {
  platform_alert_delivery_slo
  critical_alert_reescalation
  database_restore_drill
  api_rollback_drill
  worker_rollback_drill
  contract_invariant_suite
  backend_integration_suite
  end_to_end_finance_flows
  secret_handling_review
  role_review
}

enum ReleaseReadinessEnvironment {
  development
  ci
  staging
  production_like
  production
}

enum ReleaseReadinessEvidenceStatus {
  pending
  passed
  failed
}

enum ReleaseReadinessApprovalStatus {
  pending_approval
  approved
  rejected
  superseded
}

model CustomerAccountIncidentPackageRelease {
  id                      String                                      @id @default(cuid())
  customerAccountId       String
  customerAccount         CustomerAccount                             @relation(fields: [customerAccountId], references: [id])
  status                  CustomerAccountIncidentPackageReleaseStatus @default(pending_approval)
  exportMode              IncidentPackageExportMode
  releaseTarget           IncidentPackageReleaseTarget
  releaseReasonCode       String
  requestedByOperatorId   String
  requestedByOperatorRole String?
  approvedByOperatorId    String?
  approvedByOperatorRole  String?
  rejectedByOperatorId    String?
  rejectedByOperatorRole  String?
  releasedByOperatorId    String?
  releasedByOperatorRole  String?
  requestNote             String?
  approvalNote            String?
  rejectionNote           String?
  releaseNote             String?
  artifactChecksumSha256  String
  artifactPayload         Json
  requestedAt             DateTime                                    @default(now())
  approvedAt              DateTime?
  rejectedAt              DateTime?
  releasedAt              DateTime?
  expiresAt               DateTime?
  createdAt               DateTime                                    @default(now())
  updatedAt               DateTime                                    @updatedAt

  @@index([customerAccountId, status])
  @@index([status, requestedAt])
  @@index([status, approvedAt])
  @@index([status, releasedAt])
  @@index([exportMode, status])
  @@index([releaseTarget, status])
  @@index([requestedByOperatorId, requestedAt])
  @@index([approvedByOperatorId, approvedAt])
  @@index([releasedByOperatorId, releasedAt])
}

model StakingPoolGovernanceRequest {
  id                     String                            @id @default(cuid())
  rewardRate             Int
  status                 StakingPoolGovernanceRequestStatus @default(pending_approval)
  requestedByOperatorId  String
  requestedByOperatorRole String?
  approvedByOperatorId   String?
  approvedByOperatorRole String?
  rejectedByOperatorId   String?
  rejectedByOperatorRole String?
  executedByOperatorId   String?
  executedByOperatorRole String?
  requestNote            String?
  approvalNote           String?
  rejectionNote          String?
  executionNote          String?
  executionFailureReason String?
  blockchainTransactionHash String?
  stakingPoolId          Int?                              @unique
  stakingPool            StakingPool?                      @relation(fields: [stakingPoolId], references: [id])
  requestedAt            DateTime                          @default(now())
  approvedAt             DateTime?
  rejectedAt             DateTime?
  executedAt             DateTime?
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  governedExecutionRequests GovernedTreasuryExecutionRequest[]

  @@index([status, requestedAt])
  @@index([requestedByOperatorId, requestedAt])
  @@index([approvedByOperatorId, approvedAt])
  @@index([executedByOperatorId, executedAt])
}

model ReleaseReadinessEvidence {
  id                       String                         @id @default(cuid())
  evidenceType             ReleaseReadinessEvidenceType
  environment              ReleaseReadinessEnvironment
  status                   ReleaseReadinessEvidenceStatus
  releaseIdentifier        String?
  rollbackReleaseIdentifier String?
  backupReference          String?
  summary                  String
  note                     String?
  operatorId               String
  operatorRole             String?
  runbookPath              String?
  evidenceLinks            String[]
  evidencePayload          Json?
  startedAt                DateTime?
  completedAt              DateTime?
  observedAt               DateTime                       @default(now())
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  @@index([evidenceType, environment, observedAt])
  @@index([status, observedAt])
  @@index([operatorId, observedAt])
  @@index([releaseIdentifier, observedAt])
}

model ReleaseReadinessApproval {
  id                            String                         @id @default(cuid())
  releaseIdentifier             String
  environment                   ReleaseReadinessEnvironment
  launchClosurePackId           String?
  launchClosurePackVersion      Int?
  launchClosurePackChecksumSha256 String?
  rollbackReleaseIdentifier     String?
  status                        ReleaseReadinessApprovalStatus @default(pending_approval)
  summary                       String
  requestNote                   String?
  approvalNote                  String?
  rejectionNote                 String?
  requestedByOperatorId         String
  requestedByOperatorRole       String?
  approvedByOperatorId          String?
  approvedByOperatorRole        String?
  rejectedByOperatorId          String?
  rejectedByOperatorRole        String?
  supersededByOperatorId        String?
  supersededByOperatorRole      String?
  supersedesApprovalId          String?                        @unique
  supersededByApprovalId        String?                        @unique
  securityConfigurationComplete Boolean                        @default(false)
  accessAndGovernanceComplete   Boolean                        @default(false)
  dataAndRecoveryComplete       Boolean                        @default(false)
  platformHealthComplete        Boolean                        @default(false)
  functionalProofComplete       Boolean                        @default(false)
  contractAndChainProofComplete Boolean                        @default(false)
  finalSignoffComplete          Boolean                        @default(false)
  unresolvedRisksAccepted       Boolean                        @default(false)
  openBlockers                  String[]
  residualRiskNote              String?
  evidenceSnapshot              Json
  blockerSnapshot               Json
  decisionDriftSnapshot         Json?
  decisionDriftCapturedAt       DateTime?
  requestedAt                   DateTime                       @default(now())
  approvedAt                    DateTime?
  rejectedAt                    DateTime?
  supersededAt                  DateTime?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  launchClosurePack             ReleaseLaunchClosurePack?      @relation(fields: [launchClosurePackId], references: [id])

  @@index([releaseIdentifier, environment, requestedAt])
  @@index([status, requestedAt])
  @@index([requestedByOperatorId, requestedAt])
  @@index([approvedByOperatorId, approvedAt])
  @@index([launchClosurePackId])
  @@index([supersedesApprovalId])
  @@index([supersededByApprovalId])
}

model ReleaseLaunchClosurePack {
  id                     String                      @id @default(cuid())
  releaseIdentifier      String
  environment            ReleaseReadinessEnvironment
  version                Int
  generatedByOperatorId  String
  generatedByOperatorRole String?
  artifactChecksumSha256 String
  artifactPayload        Json
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  approvals              ReleaseReadinessApproval[]

  @@unique([releaseIdentifier, environment, version])
  @@index([releaseIdentifier, environment, createdAt])
  @@index([generatedByOperatorId, createdAt])
}
