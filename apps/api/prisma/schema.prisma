datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String           @unique
  supabaseUserId  String
  ethereumAddress String?          @default("")
  createdAt       DateTime         @default(now())
  deposits        PoolDeposit[]
  withdrawals     PoolWithdrawal[]
}

model Customer {
  id                 String              @id @default(cuid())
  supabaseUserId     String              @unique
  email              String              @unique
  firstName          String?
  lastName           String?
  passwordHash       String?
  depositEmailNotificationsEnabled       Boolean             @default(true)
  withdrawalEmailNotificationsEnabled    Boolean             @default(true)
  loanEmailNotificationsEnabled          Boolean             @default(true)
  productUpdateEmailNotificationsEnabled Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           CustomerAccount[]
  reviewCases        ReviewCase[]
  auditEvents        AuditEvent[]
  oversightIncidents OversightIncident[] @relation("OversightIncidentCustomer")
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
}

model CustomerAccount {
  id                              String                       @id @default(cuid())
  customerId                      String                       @unique
  customer                        Customer                     @relation(fields: [customerId], references: [id])
  status                          AccountLifecycleStatus       @default(registered)
  activatedAt                     DateTime?
  restrictedAt                    DateTime?
  restrictedFromStatus            AccountLifecycleStatus?
  restrictionReasonCode           String?
  restrictedByOperatorId          String?
  restrictedByOversightIncidentId String?
  restrictionReleasedAt           DateTime?
  restrictionReleasedByOperatorId String?
  frozenAt                        DateTime?
  closedAt                        DateTime?
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt
  wallets                         Wallet[]
  transactionIntents              TransactionIntent[]
  reviewCases                     ReviewCase[]
  oversightIncidents              OversightIncident[]          @relation("OversightIncidentCustomerAccount")
  restrictionRecords              CustomerAccountRestriction[]

  @@index([status])
  @@index([restrictedByOversightIncidentId])
  ledgerAccounts                  LedgerAccount[]
  assetBalances                   CustomerAssetBalance[]
  incidentPackageReleases         CustomerAccountIncidentPackageRelease[]
  ledgerReconciliationMismatches  LedgerReconciliationMismatch[]
  loanApplications                LoanApplication[]
  loanAgreements                  LoanAgreement[]
  loanStatements                  LoanStatement[]
  solvencyLiabilityLeaves         SolvencyLiabilityLeaf[]
}

model Wallet {
  id                 String              @id @default(cuid())
  customerAccountId  String?
  customerAccount    CustomerAccount?    @relation(fields: [customerAccountId], references: [id])
  chainId            Int
  address            String
  kind               WalletKind
  custodyType        WalletCustodyType
  status             WalletStatus        @default(pending)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sourceIntents      TransactionIntent[] @relation("SourceWallet")
  destinationIntents TransactionIntent[] @relation("DestinationWallet")
  solvencyReserveEvidence SolvencyReserveEvidence[]

  @@unique([chainId, address])
  @@index([customerAccountId])
  @@index([kind, custodyType])
  @@index([status])
}

model Asset {
  id                 String              @id @default(cuid())
  chainId            Int
  symbol             String
  displayName        String
  decimals           Int
  assetType          AssetType
  contractAddress    String?
  status             AssetStatus         @default(active)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  transactionIntents TransactionIntent[]

  @@unique([chainId, symbol])
  @@unique([chainId, contractAddress])
  @@index([assetType, status])
  ledgerAccounts     LedgerAccount[]
  ledgerJournals     LedgerJournal[]
  customerBalances   CustomerAssetBalance[]
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
  solvencyAssetSnapshots SolvencyAssetSnapshot[]
  solvencyReserveEvidence SolvencyReserveEvidence[]
  solvencyIssues     SolvencyIssue[]
  requestedBorrowLoanApplications LoanApplication[] @relation("RequestedBorrowAsset")
  requestedCollateralLoanApplications LoanApplication[] @relation("RequestedCollateralAsset")
  borrowedLoanAgreements LoanAgreement[] @relation("LoanBorrowAsset")
  collateralizedLoanAgreements LoanAgreement[] @relation("LoanCollateralAsset")
  loanCollateralPositions LoanCollateralPosition[]
  loanRepaymentEvents LoanRepaymentEvent[] @relation("LoanRepaymentAsset")
  solvencyLiabilityLeaves SolvencyLiabilityLeaf[]
  governedExecutionRequests GovernedTreasuryExecutionRequest[]
}

model TransactionIntent {
  id                           String                  @id @default(cuid())
  customerAccountId            String?
  customerAccount              CustomerAccount?        @relation(fields: [customerAccountId], references: [id])
  assetId                      String
  asset                        Asset                   @relation(fields: [assetId], references: [id])
  sourceWalletId               String?
  sourceWallet                 Wallet?                 @relation("SourceWallet", fields: [sourceWalletId], references: [id])
  destinationWalletId          String?
  destinationWallet            Wallet?                 @relation("DestinationWallet", fields: [destinationWalletId], references: [id])
  externalAddress              String?
  chainId                      Int
  intentType                   TransactionIntentType
  status                       TransactionIntentStatus
  policyDecision               PolicyDecision          @default(pending)
  requestedAmount              Decimal                 @db.Decimal(36, 18)
  settledAmount                Decimal?                @db.Decimal(36, 18)
  idempotencyKey               String                  @unique
  failureCode                  String?
  failureReason                String?
  executionFailureCategory     WithdrawalExecutionFailureCategory?
  executionFailureObservedAt   DateTime?
  executionClaimedAt           DateTime?
  executionClaimedByWorkerId   String?
  manualInterventionRequiredAt DateTime?
  manualInterventionReviewCaseId String?
  manualInterventionReviewCase ReviewCase?             @relation("ManualInterventionReviewCase", fields: [manualInterventionReviewCaseId], references: [id])
  manuallyResolvedAt           DateTime?
  manualResolutionReasonCode   String?
  manualResolutionNote         String?
  manualResolvedByOperatorId   String?
  manualResolutionOperatorRole String?
  manualResolutionReviewCaseId String?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  blockchainTransactions       BlockchainTransaction[]
  reviewCases                  ReviewCase[]

  @@index([customerAccountId])
  @@index([assetId])
  @@index([sourceWalletId])
  @@index([destinationWalletId])
  @@index([chainId, intentType])
  @@index([status, policyDecision])
  @@index([chainId, externalAddress])
  @@index([status, manuallyResolvedAt])
  @@index([status, executionClaimedAt])
  @@index([executionFailureCategory, updatedAt])
  @@index([manualInterventionRequiredAt, updatedAt])
  @@index([manualInterventionReviewCaseId])
  @@index([manualResolvedByOperatorId, manuallyResolvedAt])
  @@index([manualResolutionReasonCode, manuallyResolvedAt])
  ledgerJournals               LedgerJournal[]
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]
}

model BlockchainTransaction {
  id                  String                      @id @default(cuid())
  transactionIntentId String
  transactionIntent   TransactionIntent           @relation(fields: [transactionIntentId], references: [id])
  chainId             Int
  txHash              String?                     @unique
  nonce               Int?
  serializedTransaction String?
  status              BlockchainTransactionStatus
  fromAddress         String?
  toAddress           String?
  broadcastAt         DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  confirmedAt         DateTime?

  @@index([transactionIntentId])
  @@index([chainId, status])
}

model ReviewCase {
  id                  String             @id @default(cuid())
  customerId          String?
  customer            Customer?          @relation(fields: [customerId], references: [id])
  customerAccountId   String?
  customerAccount     CustomerAccount?   @relation(fields: [customerAccountId], references: [id])
  transactionIntentId String?
  transactionIntent   TransactionIntent? @relation(fields: [transactionIntentId], references: [id])
  type                ReviewCaseType
  status              ReviewCaseStatus   @default(open)
  reasonCode          String?
  notes               String?
  assignedOperatorId  String?
  startedAt           DateTime?
  resolvedAt          DateTime?
  dismissedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  events              ReviewCaseEvent[]
  manualInterventionIntents TransactionIntent[] @relation("ManualInterventionReviewCase")
  restrictionReleaseReviews CustomerAccountRestriction[] @relation("RestrictionReleaseReviewCase")
  ledgerReconciliationMismatches LedgerReconciliationMismatch[]

  @@index([customerId])
  @@index([customerAccountId])
  @@index([transactionIntentId])
  @@index([type, status])
  @@index([reasonCode])
  @@index([status, assignedOperatorId])
}

model AuditEvent {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  actorType  String
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@index([actorType, actorId])
  @@index([targetType, targetId])
}

model StakingPool {
  id                Int              @id @default(autoincrement())
  blockchainPoolId  Int?             @unique
  rewardRate        Int
  totalStakedAmount BigInt           @default(0)
  totalRewardsPaid  BigInt           @default(0)
  poolStatus        PoolStatus       @default(disabled)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deposits          PoolDeposit[]
  withdrawals       PoolWithdrawal[]
  governanceRequest StakingPoolGovernanceRequest?
}

enum AccountLifecycleStatus {
  registered
  email_verified
  review_required
  active
  restricted
  frozen
  closed
}

enum WalletKind {
  embedded
  external
  treasury
  operational
  contract
}

enum WalletCustodyType {
  platform_managed
  customer_external
  multisig_controlled
  contract_controlled
}

enum WalletStatus {
  pending
  active
  restricted
  archived
}

enum AssetType {
  native
  erc20
}

enum AssetStatus {
  active
  disabled
}

enum TransactionIntentType {
  deposit
  withdrawal
  vault_subscription
  vault_redemption
  treasury_transfer
  adjustment
}

enum TransactionIntentStatus {
  requested
  review_required
  approved
  queued
  broadcast
  confirmed
  settled
  failed
  cancelled
  manually_resolved
}

enum PolicyDecision {
  pending
  approved
  denied
  review_required
}

enum BlockchainTransactionStatus {
  created
  signed
  broadcast
  confirmed
  failed
  replaced
  dropped
}

enum WithdrawalExecutionFailureCategory {
  retryable
  permanent
  manual_intervention_required
}

enum ReviewCaseStatus {
  open
  in_progress
  resolved
  dismissed
}

enum ReviewCaseType {
  account_review
  withdrawal_review
  reconciliation_review
  manual_intervention
}

enum PoolStatus {
  active
  disabled
  paused
  closed
  completed
}

model PoolDeposit {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool   @relation(fields: [stakingPoolId], references: [id])
  amountStaked    BigInt
  transactionHash String?       @unique @default("")
  status          DepositStatus @default(pending)
  timestamp       DateTime      @default(now())
}

enum DepositStatus {
  pending
  completed
  failed
}

model PoolWithdrawal {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool      @relation(fields: [stakingPoolId], references: [id])
  amountWithdrawn BigInt
  transactionHash String?          @unique @default("")
  status          WithdrawalStatus @default(pending)
  timestamp       DateTime         @default(now())
}

enum WithdrawalStatus {
  pending
  completed
  failed
}

model LedgerAccount {
  id                String            @id @default(cuid())
  ledgerKey         String            @unique
  accountType       LedgerAccountType
  chainId           Int
  assetId           String
  asset             Asset             @relation(fields: [assetId], references: [id])
  customerAccountId String?
  customerAccount   CustomerAccount?  @relation(fields: [customerAccountId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ledgerPostings    LedgerPosting[]

  @@index([accountType, chainId, assetId])
  @@index([customerAccountId, assetId])
}

model LedgerJournal {
  id                   String              @id @default(cuid())
  transactionIntentId  String?
  transactionIntent    TransactionIntent?  @relation(fields: [transactionIntentId], references: [id])
  loanAgreementId      String?
  loanAgreement        LoanAgreement?      @relation(fields: [loanAgreementId], references: [id])
  loanRepaymentEventId String?
  loanRepaymentEvent   LoanRepaymentEvent? @relation(fields: [loanRepaymentEventId], references: [id])
  journalType          LedgerJournalType
  chainId              Int
  assetId              String
  asset                Asset               @relation(fields: [assetId], references: [id])
  postedAt             DateTime            @default(now())
  createdAt            DateTime            @default(now())
  ledgerPostings       LedgerPosting[]

  @@index([journalType, chainId])
  @@index([assetId])
  @@index([transactionIntentId])
  @@index([loanAgreementId])
  @@index([loanRepaymentEventId])
  @@unique([transactionIntentId, journalType])
  @@unique([loanAgreementId, journalType])
  @@unique([loanRepaymentEventId, journalType])
}

model LedgerPosting {
  id              String                 @id @default(cuid())
  ledgerJournalId String
  ledgerJournal   LedgerJournal          @relation(fields: [ledgerJournalId], references: [id])
  ledgerAccountId String
  ledgerAccount   LedgerAccount          @relation(fields: [ledgerAccountId], references: [id])
  direction       LedgerPostingDirection
  amount          Decimal                @db.Decimal(36, 18)
  createdAt       DateTime               @default(now())

  @@index([ledgerJournalId])
  @@index([ledgerAccountId, direction])
}

model CustomerAssetBalance {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])
  assetId           String
  asset             Asset           @relation(fields: [assetId], references: [id])
  availableBalance  Decimal         @default(0) @db.Decimal(36, 18)
  pendingBalance    Decimal         @default(0) @db.Decimal(36, 18)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([customerAccountId, assetId])
  @@index([assetId])
}

enum SolvencySnapshotStatus {
  healthy
  warning
  critical
  failed
}

enum SolvencyEvidenceFreshness {
  fresh
  stale
  missing
  unknown
}

enum SolvencyIssueClassification {
  healthy
  informational_drift
  stale_evidence
  reconciliation_mismatch
  reserve_shortfall
  unknown_reserve_state
  liability_computation_failure
  critical_solvency_risk
}

enum SolvencyIssueSeverity {
  info
  warning
  critical
}

enum SolvencyReserveSourceType {
  treasury_wallet
  operational_wallet
  contract_wallet
}

enum SolvencyPolicyStateStatus {
  normal
  guarded
  paused
}

enum SolvencyPolicyResumeRequestStatus {
  pending_approval
  approved
  rejected
}

enum GovernedExecutionOverrideRequestStatus {
  pending_approval
  approved
  rejected
  expired
}

enum GovernedTreasuryExecutionRequestType {
  loan_contract_creation
  staking_pool_creation
}

enum GovernedTreasuryExecutionRequestStatus {
  pending_execution
  executed
  execution_failed
  cancelled
}

enum GovernedTreasuryExecutionDispatchStatus {
  not_dispatched
  dispatched
  dispatch_failed
}

model SolvencySnapshot {
  id                         String                    @id @default(cuid())
  environment                WorkerRuntimeEnvironment
  chainId                    Int
  status                     SolvencySnapshotStatus
  evidenceFreshness          SolvencyEvidenceFreshness
  generatedAt                DateTime                  @default(now())
  completedAt                DateTime?
  latestReconciliationScanRunId String?
  latestReconciliationScanRun LedgerReconciliationScanRun? @relation(fields: [latestReconciliationScanRunId], references: [id])
  totalLiabilityAmount       Decimal                   @default(0) @db.Decimal(36, 18)
  totalUsableReserveAmount   Decimal                   @default(0) @db.Decimal(36, 18)
  totalObservedReserveAmount Decimal                   @default(0) @db.Decimal(36, 18)
  totalEncumberedReserveAmount Decimal                 @default(0) @db.Decimal(36, 18)
  totalReserveDeltaAmount    Decimal                   @default(0) @db.Decimal(36, 18)
  assetCount                 Int                       @default(0)
  issueCount                 Int                       @default(0)
  policyActionsTriggered     Boolean                   @default(false)
  summarySnapshot            Json?
  policyActionSnapshot       Json?
  failureCode                String?
  failureMessage             String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  assetSnapshots             SolvencyAssetSnapshot[]
  issues                     SolvencyIssue[]
  reserveEvidence            SolvencyReserveEvidence[]
  policyStates               SolvencyPolicyState[]
  liabilityLeaves            SolvencyLiabilityLeaf[]
  reports                    SolvencyReport[]
  resumeRequests             SolvencyPolicyResumeRequest[]

  @@index([environment, generatedAt])
  @@index([status, generatedAt])
  @@index([evidenceFreshness, generatedAt])
  @@index([latestReconciliationScanRunId])
}

model SolvencyAssetSnapshot {
  id                         String                    @id @default(cuid())
  snapshotId                 String
  snapshot                   SolvencySnapshot          @relation(fields: [snapshotId], references: [id])
  assetId                    String
  asset                      Asset                     @relation(fields: [assetId], references: [id])
  status                     SolvencySnapshotStatus
  evidenceFreshness          SolvencyEvidenceFreshness
  liabilityAvailableAmount   Decimal                   @default(0) @db.Decimal(36, 18)
  liabilityReservedAmount    Decimal                   @default(0) @db.Decimal(36, 18)
  pendingCreditAmount        Decimal                   @default(0) @db.Decimal(36, 18)
  totalLiabilityAmount       Decimal                   @default(0) @db.Decimal(36, 18)
  projectionAvailableAmount  Decimal                   @default(0) @db.Decimal(36, 18)
  projectionPendingAmount    Decimal                   @default(0) @db.Decimal(36, 18)
  observedReserveAmount      Decimal                   @default(0) @db.Decimal(36, 18)
  usableReserveAmount        Decimal                   @default(0) @db.Decimal(36, 18)
  encumberedReserveAmount    Decimal                   @default(0) @db.Decimal(36, 18)
  excludedReserveAmount      Decimal                   @default(0) @db.Decimal(36, 18)
  reserveDeltaAmount         Decimal                   @default(0) @db.Decimal(36, 18)
  reserveRatioBps            Int?
  openReconciliationMismatchCount Int                  @default(0)
  criticalReconciliationMismatchCount Int              @default(0)
  issueCount                 Int                       @default(0)
  liabilityMerkleRoot        String?
  liabilityLeafCount         Int                       @default(0)
  liabilitySetChecksumSha256 String?
  summarySnapshot            Json?
  createdAt                  DateTime                  @default(now())

  @@unique([snapshotId, assetId])
  @@index([assetId, createdAt])
  @@index([status, createdAt])
}

model SolvencyLiabilityLeaf {
  id                       String           @id @default(cuid())
  snapshotId               String
  snapshot                 SolvencySnapshot @relation(fields: [snapshotId], references: [id])
  assetId                  String
  asset                    Asset            @relation(fields: [assetId], references: [id])
  customerAccountId        String
  customerAccount          CustomerAccount  @relation(fields: [customerAccountId], references: [id])
  leafIndex                Int
  availableLiabilityAmount Decimal          @default(0) @db.Decimal(36, 18)
  reservedLiabilityAmount  Decimal          @default(0) @db.Decimal(36, 18)
  pendingCreditAmount      Decimal          @default(0) @db.Decimal(36, 18)
  totalLiabilityAmount     Decimal          @default(0) @db.Decimal(36, 18)
  leafHash                 String
  canonicalPayload         Json
  createdAt                DateTime         @default(now())

  @@unique([snapshotId, assetId, customerAccountId])
  @@index([snapshotId, assetId, leafIndex])
  @@index([customerAccountId, snapshotId])
}

model SolvencyReport {
  id                     String                    @id @default(cuid())
  snapshotId             String
  snapshot               SolvencySnapshot          @relation(fields: [snapshotId], references: [id])
  environment            WorkerRuntimeEnvironment
  chainId                Int
  reportVersion          Int                       @default(1)
  reportHash             String                    @unique
  reportChecksumSha256   String
  canonicalPayload       Json
  canonicalPayloadText   String
  signature              String
  signatureAlgorithm     String
  signerAddress          String
  publishedAt            DateTime                  @default(now())
  createdAt              DateTime                  @default(now())

  @@unique([snapshotId])
  @@index([environment, publishedAt])
}

model SolvencyReserveEvidence {
  id                         String                    @id @default(cuid())
  snapshotId                 String
  snapshot                   SolvencySnapshot          @relation(fields: [snapshotId], references: [id])
  assetId                    String
  asset                      Asset                     @relation(fields: [assetId], references: [id])
  walletId                   String?
  wallet                     Wallet?                   @relation(fields: [walletId], references: [id])
  reserveSourceType          SolvencyReserveSourceType
  walletAddress              String?
  walletKind                 WalletKind?
  custodyType                WalletCustodyType?
  evidenceFreshness          SolvencyEvidenceFreshness
  observedBalanceAmount      Decimal?                  @db.Decimal(36, 18)
  usableBalanceAmount        Decimal?                  @db.Decimal(36, 18)
  encumberedBalanceAmount    Decimal?                  @db.Decimal(36, 18)
  excludedBalanceAmount      Decimal?                  @db.Decimal(36, 18)
  observedAt                 DateTime?
  staleAfterSeconds          Int
  readErrorCode              String?
  readErrorMessage           String?
  metadata                   Json?
  createdAt                  DateTime                  @default(now())

  @@index([snapshotId, assetId, createdAt])
  @@index([walletId, assetId, createdAt])
  @@index([evidenceFreshness, createdAt])
}

model SolvencyIssue {
  id                         String                    @id @default(cuid())
  snapshotId                 String
  snapshot                   SolvencySnapshot          @relation(fields: [snapshotId], references: [id])
  assetId                    String?
  asset                      Asset?                    @relation(fields: [assetId], references: [id])
  classification             SolvencyIssueClassification
  severity                   SolvencyIssueSeverity
  reasonCode                 String
  summary                    String
  description                String
  recommendedAction          String?
  metadata                   Json?
  createdAt                  DateTime                  @default(now())

  @@index([snapshotId, severity, createdAt])
  @@index([assetId, classification, createdAt])
  @@index([classification, severity, createdAt])
}

model SolvencyPolicyState {
  id                         String                    @id @default(cuid())
  environment                WorkerRuntimeEnvironment  @unique
  status                     SolvencyPolicyStateStatus
  pauseWithdrawalApprovals   Boolean                   @default(false)
  pauseManagedWithdrawalExecution Boolean              @default(false)
  pauseLoanFunding           Boolean                   @default(false)
  pauseStakingWrites         Boolean                   @default(false)
  requireManualOperatorReview Boolean                  @default(false)
  latestSnapshotId           String?
  latestSnapshot             SolvencySnapshot?         @relation(fields: [latestSnapshotId], references: [id])
  triggeredAt                DateTime?
  clearedAt                  DateTime?
  reasonCode                 String?
  reasonSummary              String?
  manualResumeRequired       Boolean                   @default(false)
  manualResumeRequestedAt    DateTime?
  manualResumeApprovedAt     DateTime?
  manualResumeApprovedByOperatorId String?
  manualResumeApprovedByOperatorRole String?
  metadata                   Json?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  resumeRequests             SolvencyPolicyResumeRequest[]

  @@index([status, updatedAt])
  @@index([latestSnapshotId])
}

model SolvencyPolicyResumeRequest {
  id                       String                           @id @default(cuid())
  environment              WorkerRuntimeEnvironment
  policyStateId            String
  policyState              SolvencyPolicyState              @relation(fields: [policyStateId], references: [id])
  snapshotId               String
  snapshot                 SolvencySnapshot                 @relation(fields: [snapshotId], references: [id])
  status                   SolvencyPolicyResumeRequestStatus
  requestedByOperatorId    String
  requestedByOperatorRole  String
  requestNote              String?
  expectedPolicyUpdatedAt  DateTime
  requestedAt              DateTime                         @default(now())
  approvedByOperatorId     String?
  approvedByOperatorRole   String?
  approvalNote             String?
  approvedAt               DateTime?
  rejectedByOperatorId     String?
  rejectedByOperatorRole   String?
  rejectionNote            String?
  rejectedAt               DateTime?
  createdAt                DateTime                         @default(now())
  updatedAt                DateTime                         @updatedAt

  @@index([environment, status, requestedAt])
  @@index([policyStateId, status, requestedAt])
  @@index([snapshotId, status, requestedAt])
}

model GovernedExecutionOverrideRequest {
  id                             String                                @id @default(cuid())
  environment                    WorkerRuntimeEnvironment
  status                         GovernedExecutionOverrideRequestStatus
  allowUnsafeWithdrawalExecution Boolean                               @default(false)
  allowDirectLoanFunding         Boolean                               @default(false)
  allowDirectStakingWrites       Boolean                               @default(false)
  reasonCode                     String
  requestNote                    String?
  requestedByOperatorId          String
  requestedByOperatorRole        String
  requestedAt                    DateTime                              @default(now())
  expiresAt                      DateTime
  approvedByOperatorId           String?
  approvedByOperatorRole         String?
  approvalNote                   String?
  approvedAt                     DateTime?
  rejectedByOperatorId           String?
  rejectedByOperatorRole         String?
  rejectionNote                  String?
  rejectedAt                     DateTime?
  createdAt                      DateTime                              @default(now())
  updatedAt                      DateTime                              @updatedAt

  @@index([environment, status, requestedAt])
  @@index([environment, status, expiresAt])
}

model GovernedTreasuryExecutionRequest {
  id                           String                               @id @default(cuid())
  environment                  WorkerRuntimeEnvironment
  chainId                      Int
  executionType                GovernedTreasuryExecutionRequestType
  status                       GovernedTreasuryExecutionRequestStatus @default(pending_execution)
  targetType                   String
  targetId                     String
  loanAgreementId              String?
  loanAgreement                LoanAgreement?                       @relation(fields: [loanAgreementId], references: [id])
