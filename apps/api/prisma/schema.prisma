datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int              @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String           @unique
  supabaseUserId  String
  ethereumAddress String?          @default("")
  createdAt       DateTime         @default(now())
  deposits        PoolDeposit[]
  withdrawals     PoolWithdrawal[]
}

model Customer {
  id             String            @id @default(cuid())
  supabaseUserId String            @unique
  email          String            @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  accounts       CustomerAccount[]
}

model CustomerAccount {
  id           String                 @id @default(cuid())
  customerId   String                 @unique
  customer     Customer               @relation(fields: [customerId], references: [id])
  status       AccountLifecycleStatus @default(registered)
  activatedAt  DateTime?
  restrictedAt DateTime?
  frozenAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([status])
}

model StakingPool {
  id                Int              @id @default(autoincrement())
  blockchainPoolId  Int?             @unique
  rewardRate        Int
  totalStakedAmount BigInt           @default(0)
  totalRewardsPaid  BigInt           @default(0)
  poolStatus        PoolStatus       @default(disabled)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deposits          PoolDeposit[]
  withdrawals       PoolWithdrawal[]
}

enum AccountLifecycleStatus {
  registered
  email_verified
  review_required
  active
  restricted
  frozen
  closed
}

enum PoolStatus {
  active
  disabled
  paused
  closed
  completed
}

model PoolDeposit {
  id              Int           @id @default(autoincrement())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool   @relation(fields: [stakingPoolId], references: [id])
  amountStaked    BigInt
  transactionHash String?       @unique @default("")
  status          DepositStatus @default(pending)
  timestamp       DateTime      @default(now())
}

enum DepositStatus {
  pending
  completed
  failed
}

model PoolWithdrawal {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  stakingPoolId   Int
  stakingPool     StakingPool      @relation(fields: [stakingPoolId], references: [id])
  amountWithdrawn BigInt
  transactionHash String?          @unique @default("")
  status          WithdrawalStatus @default(pending)
  timestamp       DateTime         @default(now())
}

enum WithdrawalStatus {
  pending
  completed
  failed
}
