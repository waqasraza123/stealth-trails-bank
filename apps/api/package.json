{
  "name": "@stealth-trails-bank/api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS Backend for Blockchain-Based Bank",
  "main": "dist/main.js",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "backfill:customer-accounts": "ts-node src/scripts/backfill-customer-accounts.ts",
    "backfill:customer-wallets": "ts-node src/scripts/backfill-customer-wallets.ts",
    "test": "jest --config ./jest.config.ts --runInBand",
    "test:unit": "jest --config ./jest.config.ts --runInBand --testPathIgnorePatterns=integration\\.spec\\.ts$",
    "test:integration": "jest --config ./jest.config.ts --runInBand --testPathPattern=integration\\.spec\\.ts$",
    "test:coverage": "jest --config ./jest.config.ts --runInBand --coverage",
    "test:watch": "jest --config ./jest.config.ts --watch",
    "audit:wallet-projection-coverage": "ts-node src/scripts/audit-wallet-projection-coverage.ts",
    "repair:customer-wallet-projections": "ts-node src/scripts/repair-customer-wallet-projections.ts",
    "repair:customer-account-wallet-projections": "ts-node src/scripts/repair-customer-account-wallet-projections.ts",
    "export:wallet-projection-manual-review-queue": "ts-node src/scripts/export-wallet-projection-manual-review-queue.ts",
    "repair:missing-customer-projections": "ts-node src/scripts/repair-missing-customer-projections.ts",
    "repair:wallet-projection-safe-batch": "ts-node src/scripts/repair-wallet-projection-safe-batch.ts",
    "audit:wallet-projection-repair-events": "ts-node src/scripts/audit-wallet-projection-repair-events.ts",
    "release-readiness:probe": "ts-node src/scripts/release-readiness-drill.ts",
    "release-readiness:verify": "ts-node src/scripts/release-readiness-proof.ts",
    "release-launch-closure": "ts-node src/scripts/release-launch-closure.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.2.1",
    "@stealth-trails-bank/config": "workspace:*",
    "@stealth-trails-bank/contracts-sdk": "workspace:*",
    "@stealth-trails-bank/db": "workspace:*",
    "@stealth-trails-bank/security": "workspace:*",
    "@stealth-trails-bank/types": "workspace:*",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ethers": "^5.7.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "nestjs-joi": "^1.11.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
